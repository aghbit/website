---
import "../styles/global.css";

import bitLogo from "../assets/bit.svg";
import aghLogo from "../assets/agh.svg";
import informatykaLogo from "../assets/informatyka.svg";
import inaugurationPhoto from "../assets/inauguracja.jpg";
import hackathonPhoto from "../assets/hackathon.jpg";
import ludziePhoto from "../assets/ludzie.jpg";
import kaczkaPhoto from "../assets/kaczka.jpg";

import Layout from "../layouts/Layout.astro";
import BitSection from "../components/BitSection.astro";
import BoardPill from "../components/BoardPill.astro";
import Section from "../components/Section.astro";
import Container from "../components/Container.astro";

interface ISection {
    name: string;
    description: string;
}

const sections: ISection[] = [
    {
        name: "ALGO",
        description:
            "Algorytmika i programowanie konkurencyjne (AMPPZ, CERC!). Organizujemy sparingi i zajęcia dla znających już podstawy.",
    },
    {
        name: "AI",
        description:
            "Machine Learning, sieci neuronowe i AI. Postaw z nami swoje pierwsze kroki w tej dziedzinie podczas zdalnych wykładów!",
    },

    {
        name: "INFRA",
        description:
            "Infrastruktura IT w praktyce: tajniki pracy z Linuksem i wdrażanie aplikacji na serwery.",
    },
    {
        name: "WEB",
        description:
            "Dla pasjonatów apek webowych! Skupiamy się na konkretnym projekcie, dlatego wejściówką do sekcji jest rekrutacja ze skilla.",
    },
    {
        name: "START",
        description:
            "Dwa zespoły połączone jednym, szczytnym celem: uratować Twoje punkty ECTS!",
    },
    {
        name: "BIT MATURA x DIAMENT",
        description:
            "Zajęcia dla szkół średnich. Przygotowujemy do rozszerzonej matury z informatyki oraz Olimpiady Informatycznej.",
    },
];

const boardHead = "Michał Szymocha";

const board = [
    "Piotr Kacprzak",
    "Paweł Fornagiel",
    "Oskar Blajsz",
    "Maciej Kmąk",
    "Justyna Orłowska",
    "Madzia Śmietana",
    "Sebastian Flajszer",
    "Mateusz Kursa",
    "Michał Dudek",
    "Julian Dworzycki",
];

const footerGroups = [
    {
        title: "Dokumenty", // Or "Formalia"
        links: [{ label: "Regulamin / Statut", href: "/statut.pdf" }],
    },
    {
        title: "Social Media",
        links: [
            { label: "Facebook", href: "https://www.facebook.com/knbit" },
            { label: "GitHub", href: "https://github.com/aghbit" },
        ],
    },
    {
        title: "Kontakt",
        links: [
            {
                label: "kontakt@knbit.edu.pl",
                href: "mailto:kontakt@knbit.edu.pl",
            },
        ],
    },
];

const navLinks = [
    { label: "O nas", href: "#about" },
    { label: "Działalność", href: "#groups" },
    { label: "Zarząd", href: "#board" },
    { label: "Kontakt", href: "#contact" },
];
---

<Layout>
    <nav
        class="sticky top-0 bg-white/70 z-60 backdrop-blur-md border-b border-stone-200/50"
    >
        <Container class="flex items-center justify-between m-auto py-4">
            <div class="flex items-center gap-4">
                <a href="/" class="transition-opacity inline-block">
                    <img
                        class="h-6"
                        src={bitLogo.src}
                        alt="BIT Logo"
                        draggable="false"
                    />
                </a>
            </div>
            <ul class="hidden md:flex items-center justify-end gap-8">
                {
                    navLinks.map(({ label, href }) => (
                        <li>
                            <a
                                href={href}
                                class="nav-link text-stone-600 hover:text-black transition-colors font-medium"
                            >
                                {label}
                            </a>
                        </li>
                    ))
                }
            </ul>
            <button
                id="menu-toggle"
                class="md:hidden p-2 text-stone-600 relative z-70"
                aria-label="Toggle Menu"
            >
                <svg
                    xmlns="http://www.w3.org/2000/svg"
                    class="h-6 w-6"
                    fill="none"
                    viewBox="0 0 24 24"
                    stroke="currentColor"
                >
                    <path
                        class="line-top"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        stroke-width="2"
                        d="M4 6h16"></path>
                    <path
                        class="line-mid"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        stroke-width="2"
                        d="M4 12h16"></path>
                    <path
                        class="line-bot"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        stroke-width="2"
                        d="M4 18h16"></path>
                </svg>
            </button>
        </Container>
    </nav>
    <div
        id="mobile-menu"
        class="fixed inset-0 bg-white z-50 flex flex-col items-center justify-center gap-8 opacity-0 pointer-events-none md:hidden"
    >
        {
            navLinks.map(({ label, href }) => (
                <a
                    href={href}
                    class="mobile-nav-link text-3xl font-medium text-stone-800"
                >
                    {label}
                </a>
            ))
        }
    </div>
    <div class="relative overflow-hidden" id="bits-canvas-container">
        <canvas class="absolute top-0 left-0 -z-50 opacity-5" id="bits-canvas"
        ></canvas>
        <main>
            <Container class="m-auto relative flex justify-center">
                <div
                    class="py-16 flex flex-col gap-8 justify-center items-center h-256"
                >
                    <span class="text-6xl font-medium" id="slogan">
                        Studencka przestrzeń do wymiany wiedzy i testowania
                        pomysłów.
                    </span>
                </div>
            </Container>
        </main>
        <div
            class="absolute bottom-0 left-0 right-0 mx-auto flex items-center justify-center h-12 gap-12 p-12"
        >
            <div class="w-24 flex justify-center">
                <a href="/">
                    <img class="h-6" src={bitLogo.src} />
                </a>
            </div>
            <div class="w-24 flex justify-center">
                <a href="https://www.agh.edu.pl/" target="_blank">
                    <img class="h-16" src={aghLogo.src} />
                </a>
            </div>
            <div class="w-24 flex justify-center">
                <a
                    href="https://www.informatyka.agh.edu.pl/pl/"
                    target="_blank"
                >
                    <img class="h-16" src={informatykaLogo.src} />
                </a>
            </div>
        </div>
    </div>
    <Section class="bg-stone-100" id="about">
        <Container class="grid gap-8 relative">
            <div class="flex flex-col gap-8">
                <h2 class="text-2xl font-medium">O nas</h2>
                <p class="text-xl max-w-200">
                    W Kole Naukowym BIT studenci AGH wspólnie rozwijają i dzielą
                    się swoimi pasjami. Skupiamy osoby zafascynowane nowoczesnym
                    tworzeniem oprogramowania, technologiami webowymi,
                    algorytmami oraz sztuczną inteligencją.
                </p>
            </div>
        </Container>
    </Section>
    <Section class="p-0 bg-stone-100" id="about">
        <Container
            class="max-w-7xl p-0 grid gap-8 relative overflow-hidden h-172"
        >
            <div
                class="absolute grid gap-2 grid-cols-2 grid-rows-3"
                id="gallery"
            >
                <img
                    class="rounded-lg h-64 w-full object-cover"
                    src={kaczkaPhoto.src}
                />
                <img
                    class="row-span-2 h-full w-full rounded-lg object-cover"
                    src={inaugurationPhoto.src}
                />
                <img
                    class="row-span-2 w-full h-full rounded-lg object-cover"
                    src={hackathonPhoto.src}
                />
                <img
                    class="h-64 w-full rounded-lg object-cover"
                    src={ludziePhoto.src}
                />
            </div>
        </Container>
    </Section>
    <Section id="groups">
        <Container class="flex flex-col gap-8">
            <h2 class="text-2xl font-medium">Sekcje</h2>
            <p class="text-xl max-w-200">
                Poza realizacją własnych zainteresowań wspieramy się w nauce.
                Organizujemy zajęcia z matematyki i informatyki dla
                początkujących, aby wspólnie wymieniać się doświadczeniami i
                skuteczniej przygotowywać do zajęć uniwersyteckich.
            </p>
            <div
                class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-2 pt-12"
                id="sections"
            >
                {
                    sections.map(({ name, description }) => (
                        <BitSection name={name} description={description} />
                    ))
                }
            </div>
        </Container>
    </Section>
    <Section class="bg-stone-800 board-scroll-trigger" id="board">
        <Container class="flex flex-col gap-8">
            <h2 class="text-2xl font-medium text-white">Zarząd</h2>
            <div
                class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-5 gap-2"
                id="board-grid"
            >
                <BoardPill head name={boardHead} />
                {board.map((name) => <BoardPill name={name} />)}
            </div>
        </Container>
    </Section>
    <Section>
        <Container>
            <footer
                class="grid grid-cols-1 md:grid-cols-3 gap-12 py-16"
                id="contact"
            >
                {
                    footerGroups.map((group) => (
                        <div class="flex flex-col gap-4">
                            <h3 class="font-medium text-stone-900 ">
                                {group.title}
                            </h3>
                            <ul class="flex flex-col gap-2">
                                {group.links.map((link) => (
                                    <li>
                                        <a
                                            href={link.href}
                                            class="text-stone-600 hover:text-black transition-colors"
                                        >
                                            {link.label}
                                        </a>
                                    </li>
                                ))}
                            </ul>
                        </div>
                    ))
                }
            </footer>
        </Container>
    </Section>
</Layout>

<script>
    import gsap from "gsap";
    import { SplitText } from "gsap/SplitText";
    import { ScrollTrigger } from "gsap/ScrollTrigger";
    import { ScrollSmoother } from "gsap/ScrollSmoother";

    gsap.registerPlugin(SplitText, ScrollTrigger, ScrollSmoother);

    // Animate slogan

    const split = SplitText.create("#slogan", {
        type: "words",
    });

    gsap.from(split.words, {
        y: 50,
        duration: 1,
        autoAlpha: 0,
        stagger: 0.08,
        ease: "circ.out",
    });

    // Gallery

    const gallery = document.querySelectorAll("#gallery > *");

    gsap.from(gallery, {
        scrollTrigger: "#gallery",
        opacity: 0,
        y: 50,
        duration: 2,
        stagger: 0.1,
        ease: "power3.out",
    });

    // Sections
    const sections = document.querySelectorAll("#sections > *");

    gsap.from(sections, {
        scrollTrigger: "#sections",
        opacity: 0,
        duration: 2,
        stagger: 0.08,
        ease: "power3.out",
    });

    // Animate board pills

    const pills = document.querySelectorAll("#board-grid > *");

    gsap.from(pills, {
        scrollTrigger: ".board-scroll-trigger",
        opacity: 0,
        duration: 2,
        stagger: {
            each: 0.05,
            from: "random",
            ease: "power2.inOut",
        },
        ease: "power3.out",
    });

    // Bg Canvas

    {
        const container = document.querySelector<HTMLDivElement>(
            "#bits-canvas-container",
        )!;

        const canvas =
            document.querySelector<HTMLCanvasElement>("#bits-canvas")!;

        const ctx = canvas.getContext("2d")!;

        let width = (canvas.width = container.clientWidth);
        let height = (canvas.height = container.clientHeight);

        window.addEventListener("resize", () => {
            width = canvas.width = container.clientWidth;
            height = canvas.height = container.clientHeight;
        });
    }

    // Mobile menu (TODO: Move this to a separate component)

    const menuToggle = document.querySelector<HTMLElement>("#menu-toggle")!;
    const mobileMenu = document.querySelector<HTMLElement>("#mobile-menu")!;
    const mobileLinks =
        document.querySelectorAll<HTMLElement>(".mobile-nav-link")!;

    const menuTl = gsap.timeline({
        paused: true,
        defaults: { duration: 0.3, ease: "power2.inOut" },
    });

    gsap.set(".line-top, .line-mid, .line-bot", {
        transformOrigin: "center center",
    });

    menuTl
        // Fade out middle line
        .to(".line-mid", { opacity: 0 }, 0)
        // Move top line to center and rotate
        .to(".line-top", { y: 6, rotation: 45 }, 0)
        // Move bottom line to center and rotate
        .to(".line-bot", { y: -6, rotation: -45 }, 0)
        // 2. Open the Menu
        .to(
            mobileMenu,
            {
                opacity: 1,
                pointerEvents: "all",
                duration: 0.2,
            },
            0,
        ) // Starts at the same time as the icon animation
        .from(
            ".mobile-nav-link",
            {
                y: 20,
                opacity: 0,
                stagger: 0.05,
                duration: 0.2,
                ease: "power3.out",
            },
            "-=0.2",
        );

    let isMenuOpen = false;

    menuToggle.addEventListener("click", () => {
        isMenuOpen = !isMenuOpen;

        if (isMenuOpen) {
            menuTl.play();
            document.body.style.overflow = "hidden";
        } else {
            menuTl.reverse();
            document.body.style.overflow = "";
        }
    });

    mobileLinks.forEach((link) => {
        link.addEventListener("click", () => {
            isMenuOpen = false;
            menuTl.reverse();
            document.body.style.overflow = "";
        });
    });
</script>
