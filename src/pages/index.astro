---
import "../styles/global.css";

import bitLogo from "../assets/bit.svg";
import aghLogo from "../assets/agh.svg";
import informatykaLogo from "../assets/informatyka.svg";
import inaugurationPhoto from "../assets/inauguracja.jpg";

import Layout from "../layouts/Layout.astro";
import BitSection from "../components/BitSection.astro";
import BoardPill from "../components/BoardPill.astro";
import Section from "../components/Section.astro";
import Container from "../components/Container.astro";

interface ISubsection {
    name: string;
    description: string;
}

interface ISections {
    name: string;
    description: string;
    subsections?: ISubsection[]
}

const sections: ISections[] = [
    {
        name: "START",
        description:
            "Blok sekcji składający się z 2 głównych elementów, które łączy jeden cel - zaoszczędzić naszym drogim studentom jak najwięcej ECTS-ów.",
        subsections: [
            {
                name: "MATHS",
                description:
                    "Członkowie tej sekcji biorą \"na warsztat\" cztery potwory: Matematykę Dyskretną, Algebrę i Analizę Matematyczną.",
            },
            {
                name: "CODING",
                description:
                    "Sekcja skupia się na jak najprzyjemniejszym wprowadzeniu was w świat algorytmiki i programowania. Polecamy ją szczególnie początkującym!",
            },
        ],
    },
    {
        name: "BIT MATURA x DIAMENT",
        description:
            "Ta sekcja poświęcona jest uczniom ze szkół licealnych oraz technicznych. Organizujemy zajęcia przygotowujące naszych młodszych kolegów do egzaminu maturalnego z informatyki lub Olimpiady Informatycznej.",
    },
    {
        name: "WEB",
        description:
            "Sekcja, na którą oko powinni mieć wszyscy pasjonaci aplikacji webowych. Zespół skupia się na realizacji wyznaczonego projektu, dlatego aby do nich dołączyć należy udowodnić swoje umiejętności podczas rekrutacji.",
    },
    {
        name: "ALGO",
        description:
            "Blok dla pasjonatów algorytmiki, powołany by reprezentować nas na AMPPZ i CERC! Organizujemy też regularne sparingi i zajęcia stacjonarne dla osób początkujących, które znają już podstawy z OI/OIJ.",
    },
    {
        name: "AI",
        description:
            "Omawiamy tu zagadnienia związane z szeroko pojętą Sztuczną Inteligencją, takie jak Machine Learning czy Sieci neuronowe. Jeśli chcecie postawić pierwsze kroki w tej dziedzinie, zachęcamy do udziału w zdalnych wykładach.",
    },
    {
        name: "INFRA",
        description:
            "Sekcja skupia się na zagadnieniach infrastruktury IT, pracy z systemem Linux oraz wdrażaniu aplikacji na serwery.",
    },
];

const boardHead = "Michał Szymocha";

const board = [
    "Piotr Kacprzak",
    "Paweł Fornagiel",
    "Oskar Blajsz",
    "Maciej Kmąk",
    "Justyna Orłowska",
    "Madzia Śmietana",
    "Sebastian Flajszer",
    "Mateusz Kursa",
    "Michał Dudek",
    "Julian Dworzycki",
];

const footerGroups = [
    {
        title: "Dokumenty", // Or "Formalia"
        links: [{ label: "Regulamin / Statut", href: "/statut.pdf" }],
    },
    {
        title: "Social Media",
        links: [
            { label: "Facebook", href: "https://www.facebook.com/knbit" },
            { label: "GitHub", href: "https://github.com/aghbit" },
        ],
    },
    {
        title: "Kontakt",
        links: [
            {
                label: "kontakt@knbit.edu.pl",
                href: "mailto:kontakt@knbit.edu.pl",
            },
        ],
    },
];

const navLinks = [
    { label: "O nas", href: "#about" },
    { label: "Działalność", href: "#groups" },
    { label: "Zarząd", href: "#board" },
    { label: "Kontakt", href: "#contact" },
];
---

<Layout>
    <nav
        class="sticky top-0 bg-white/70 z-60 backdrop-blur-md border-b border-stone-200/50"
    >
        <Container class="flex items-center justify-between m-auto py-4">
            <div class="flex items-center gap-4">
                <a href="/" class="hover:opacity-80 transition-opacity">
                    <img
                        class="h-8"
                        src={bitLogo.src}
                        alt="BIT Logo"
                        draggable="false"
                    />
                </a>
            </div>

            <ul class="hidden md:flex items-center justify-end gap-8">
                {
                    navLinks.map(({ label, href }) => (
                        <li>
                            <a
                                href={href}
                                class="nav-link text-stone-600 hover:text-black transition-colors font-medium"
                            >
                                {label}
                            </a>
                        </li>
                    ))
                }
            </ul>
            <button
                id="menu-toggle"
                class="md:hidden p-2 text-stone-600 relative z-70"
                aria-label="Toggle Menu"
            >
                <svg
                    xmlns="http://www.w3.org/2000/svg"
                    class="h-6 w-6"
                    fill="none"
                    viewBox="0 0 24 24"
                    stroke="currentColor"
                >
                    <path
                        class="line-top"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        stroke-width="2"
                        d="M4 6h16"></path>
                    <path
                        class="line-mid"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        stroke-width="2"
                        d="M4 12h16"></path>
                    <path
                        class="line-bot"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        stroke-width="2"
                        d="M4 18h16"></path>
                </svg>
            </button>
        </Container>
    </nav>

    <div
        id="mobile-menu"
        class="fixed inset-0 bg-white z-50 flex flex-col items-center justify-center gap-8 opacity-0 pointer-events-none md:hidden"
    >
        {
            navLinks.map(({ label, href }) => (
                <a
                    href={href}
                    class="mobile-nav-link text-3xl font-medium text-stone-800"
                >
                    {label}
                </a>
            ))
        }
    </div>
    <div class="relative overflow-hidden" id="bits-canvas-container">
        <canvas class="absolute top-0 left-0 -z-50 opacity-5" id="bits-canvas"
        ></canvas>
        <main>
            <Container class="m-auto relative flex justify-center">
                <div
                    class="py-16 flex flex-col gap-8 justify-center items-center h-180"
                >
                    <img class="w-45" src={bitLogo.src} />
                    <span class="text-6xl font-medium text-center" id="slogan">
                        Twoje wejście do <br />
                        świata informatyki
                    </span>
                </div>
            </Container>
        </main>
        <div
            class="absolute bottom-0 left-0 right-0 mx-auto flex items-center justify-center h-12 gap-12 p-12"
        >
            <div class="w-24 flex justify-center">
                <img class="h-6" src={bitLogo.src} />
            </div>
            <div class="w-24 flex justify-center">
                <img class="h-16" src={aghLogo.src} />
            </div>
            <div class="w-24 flex justify-center">
                <img class="h-16" src={informatykaLogo.src} />
            </div>
        </div>
    </div>
    <Section class="bg-stone-100" id="about">
        <Container class="flex gap-8">
            <div class="flex flex-col gap-8">
                <h2 class="text-2xl font-medium">O nas</h2>
                <p class="text-xl">
                    Koło naukowe BIT to przede wszystkim miejsce, gdzie studenci
                    AGH mogą rozwijać swoje zainteresowania i się nimi dzielić.
                    Znajdziemy tutaj ludzi zainteresowanych nowoczesnymi
                    metodami tworzenia oprogramowania, aktualnymi technologiami
                    webowymi, a także algorytmami czy sztuczną inteligencją.
                </p>
            </div>
        </Container>
    </Section>
    <Section id="groups">
        <Container class="flex flex-col gap-8">
            <h2 class="text-2xl font-medium">Sekcje</h2>
            <p class="text-xl">
                Oprócz rozwijania swoich pasji, dzielimy się też wiedzą z
                zakresu studiów, prowadząc zajęcia wprowadzające w dziedziny
                matematyki i informatyki dla osób, które wcześniej nie miały z
                danymi zagadnieniami styczności. Wszystko po to, żeby wymienić
                się doświadczeniem i szybciej oraz lepiej przygotować się na
                zajęcia na uczelni.
            </p>
            <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-2">
                {
                    sections.map(({ name, description, subsections }) => (
                        <BitSection name={name} description={description} subsections={subsections} />
                    ))
                }
            </div>
        </Container>
    </Section>
    <Section class="bg-stone-800 board-scroll-trigger" id="board">
        <Container class="flex flex-col gap-8">
            <h2 class="text-2xl font-medium text-white">Zarząd</h2>
            <div
                class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-5 gap-2"
                id="board-grid"
            >
                <BoardPill head name={boardHead} />
                {board.map((name) => <BoardPill name={name} />)}
            </div>
        </Container>
    </Section>
    <Section>
        <Container>
            <footer
                class="grid grid-cols-1 md:grid-cols-3 gap-12 py-16"
                id="contact"
            >
                {
                    footerGroups.map((group) => (
                        <div class="flex flex-col gap-4">
                            <h3 class="font-medium text-stone-900 ">
                                {group.title}
                            </h3>
                            <ul class="flex flex-col gap-2">
                                {group.links.map((link) => (
                                    <li>
                                        <a
                                            href={link.href}
                                            class="text-stone-600 hover:text-black transition-colors"
                                        >
                                            {link.label}
                                        </a>
                                    </li>
                                ))}
                            </ul>
                        </div>
                    ))
                }
            </footer>
        </Container>
    </Section>
</Layout>

<script>
    import gsap from "gsap";
    import { SplitText } from "gsap/SplitText";
    import { ScrollTrigger } from "gsap/ScrollTrigger";

    // Animate slogan

    gsap.registerPlugin(SplitText);
    gsap.registerPlugin(ScrollTrigger);

    const split = SplitText.create("#slogan", {
        type: "words",
    });

    gsap.from(split.words, {
        y: 100,
        autoAlpha: 0,
        stagger: 0.08,
    });

    // Animate board pills

    const pills = document.querySelectorAll("#board-grid > *");

    gsap.from(pills, {
        scrollTrigger: ".board-scroll-trigger",
        opacity: 0,
        duration: 2,
        stagger: {
            each: 0.05,
            from: "random",
            ease: "power2.inOut",
        },
        ease: "power3.out",
    });

    // Bits

    {
        const container = document.querySelector<HTMLDivElement>(
            "#bits-canvas-container",
        )!;

        const canvas =
            document.querySelector<HTMLCanvasElement>("#bits-canvas")!;

        const ctx = canvas.getContext("2d")!;

        let width = (canvas.width = container.clientWidth);
        let height = (canvas.height = container.clientHeight);
        let radius = Math.max(width, height);

        const particles = Array(99);

        const images = ["/0.png", "/1.png"];

        const loadImages = images.map((src) => {
            return new Promise((resolve, reject) => {
                const img = new Image();
                img.src = src;
                img.onload = () => resolve(img);
                img.onerror = reject;
            });
        });

        Promise.all(loadImages).then((loadedImages) => {
            for (let i = 0; i < particles.length; i++) {
                particles[i] = {
                    x: 0,
                    y: 0,
                    scale: 0,
                    rotate: 0,
                    img: loadedImages[i % loadedImages.length],
                };
            }

            const tl = gsap
                .timeline({ onUpdate: draw })
                .fromTo(
                    particles,
                    {
                        x: (i) => {
                            const angle =
                                (i / particles.length) * Math.PI * 2 -
                                Math.PI / 2;

                            return Math.cos(angle * 10) * radius; // * i/particles.length
                        },
                        y: (i) => {
                            const angle =
                                (i / particles.length) * Math.PI * 2 -
                                Math.PI / 2;

                            return Math.sin(angle * 10) * radius; // * i/particles.length
                        },
                        scale: 1.1,
                        rotate: 2,
                    },
                    {
                        duration: 30,
                        ease: "sine",
                        x: 0,
                        y: 0,
                        scale: 0,
                        rotate: -1,
                        stagger: { each: -0.3, repeat: -1 },
                    },
                    0,
                )
                .seek(100);

            function draw() {
                particles.sort((a, b) => a.scale - b.scale);
                ctx.clearRect(0, 0, width, height);
                particles.forEach((p, i) => {
                    ctx.translate(width / 2, height / 2);
                    ctx.rotate(p.rotate);
                    ctx.drawImage(
                        p.img,
                        p.x,
                        p.y,
                        p.img.width * p.scale,
                        p.img.height * p.scale,
                    );
                    ctx.resetTransform();
                });
            }

            window.addEventListener("resize", () => {
                width = canvas.width = container.clientWidth;
                height = canvas.height = container.clientHeight;
                radius = Math.max(width, height);
                tl.invalidate();
            });
        });
    }

    // Mobile menu

    const menuToggle = document.querySelector<HTMLElement>("#menu-toggle")!;
    const mobileMenu = document.querySelector<HTMLElement>("#mobile-menu")!;
    const mobileLinks =
        document.querySelectorAll<HTMLElement>(".mobile-nav-link")!;

    const menuTl = gsap.timeline({
        paused: true,
        defaults: { duration: 0.3, ease: "power2.inOut" },
    });

    gsap.set(".line-top, .line-mid, .line-bot", {
        transformOrigin: "center center",
    });

    menuTl
        // Fade out middle line
        .to(".line-mid", { opacity: 0 }, 0)
        // Move top line to center and rotate
        .to(".line-top", { y: 6, rotation: 45 }, 0)
        // Move bottom line to center and rotate
        .to(".line-bot", { y: -6, rotation: -45 }, 0)
        // 2. Open the Menu
        .to(
            mobileMenu,
            {
                opacity: 1,
                pointerEvents: "all",
                duration: 0.2,
            },
            0,
        ) // Starts at the same time as the icon animation
        .from(
            ".mobile-nav-link",
            {
                y: 20,
                opacity: 0,
                stagger: 0.05,
                duration: 0.2,
                ease: "power3.out",
            },
            "-=0.2",
        );

    let isMenuOpen = false;

    menuToggle.addEventListener("click", () => {
        isMenuOpen = !isMenuOpen;

        if (isMenuOpen) {
            menuTl.play();
            document.body.style.overflow = "hidden";
        } else {
            menuTl.reverse();
            document.body.style.overflow = "";
        }
    });

    // Handle closing when a link is clicked
    mobileLinks.forEach((link) => {
        link.addEventListener("click", () => {
            isMenuOpen = false;
            menuTl.reverse();
            document.body.style.overflow = "";
        });
    });
</script>
