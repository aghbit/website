<canvas class="-z-50" id="canvas"></canvas>

<script>
    import * as THREE from "three";
    import { GLTFLoader } from "three/addons/loaders/GLTFLoader.js";

    if (window.myThreeRenderer) {
        window.myThreeRenderer.dispose();
        window.myThreeRenderer = null;
    }

    const container = document.querySelector("#bit-scene-canvas-container")!;
    const canvas = document.querySelector<HTMLCanvasElement>("#canvas")!;

    const scene = new THREE.Scene();
    const renderer = new THREE.WebGLRenderer({
        canvas,
        antialias: true,
        alpha: true,
    });

    const ratio = window.devicePixelRatio;

    renderer.setSize(
        container.clientWidth * ratio,
        container.clientHeight * ratio,
    );

    canvas.style.width = `${container.clientWidth}px`;
    canvas.style.height = `${container.clientHeight}px`;

    window.myThreeRenderer = renderer;

    const camera = new THREE.PerspectiveCamera(
        30,
        container.clientWidth / container.clientHeight,
        0.1,
        1000,
    );
    camera.position.z = 1.7;
    camera.position.y = 40;

    const directionalLight = new THREE.DirectionalLight(0xffffff, 2);
    directionalLight.position.set(-1, 2, 3);
    scene.add(directionalLight);

    // Load BIT logo

    const loader = new GLTFLoader();
    let bitLogoModel: THREE.Group | null = null;

    loader.load(
        `/models/bit.glb`,
        (gltf) => {
            bitLogoModel = gltf.scene;
            bitLogoModel.rotation.x = -0.3;
            scene.add(bitLogoModel);
        },
        undefined,
        (err) => console.error(err),
    );

    window.addEventListener("resize", () => {
        const ratio = window.devicePixelRatio;

        const width = container.clientWidth * ratio;
        const height = container.clientHeight * ratio;

        renderer.setSize(width, height);
        camera.aspect = width / height;
        camera.updateProjectionMatrix();

        canvas.style.width = `${container.clientWidth}px`;
        canvas.style.height = `${container.clientHeight}px`;
    });

    const targetRotationY = 0.4;
    const lerpFactor = 0.15; // Adjust this: 0.1 is fast/snappy, 0.02 is slow/smooth

    let mouseX = 0;
    let mouseY = 0;

    window.addEventListener("mousemove", (event) => {
        // Normalize coordinates to -1 to +1
        mouseX = (event.clientX / window.innerWidth) * 2 - 1;
        mouseY = -(event.clientY / window.innerHeight) * 2 + 1;
    });

    const swayIntensity = 0.2;

    function animate() {
        requestAnimationFrame(animate);

        // Lerp the camera position toward the target based on mouse
        camera.position.x = THREE.MathUtils.lerp(
            camera.position.x,
            mouseX * swayIntensity,
            lerpFactor,
        );

        camera.position.y = THREE.MathUtils.lerp(
            camera.position.y,
            mouseY * swayIntensity,
            lerpFactor,
        );

        camera.lookAt(0, 0, 0);

        if (bitLogoModel) {
            bitLogoModel.rotation.y = THREE.MathUtils.lerp(
                bitLogoModel.rotation.x,
                targetRotationY,
                lerpFactor,
            );
        }

        renderer.render(scene, camera);
    }

    animate();
</script>
